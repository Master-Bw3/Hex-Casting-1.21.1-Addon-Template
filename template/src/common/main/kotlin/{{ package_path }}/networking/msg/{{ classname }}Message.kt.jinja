    fun apply(msg: T, access: ClientAccess): Unit {
        {{ classname }}.LOGGER.debug("Client received packet: {}", this)
        when (msg) {
            is {{ classname }}MessageS2C -> msg.applyOnClient(access)
            else -> {{ classname }}.LOGGER.warn("Message not handled on client: {}", msg::class)
        }
    }

    fun register(channel: OwoNetChannel) {
