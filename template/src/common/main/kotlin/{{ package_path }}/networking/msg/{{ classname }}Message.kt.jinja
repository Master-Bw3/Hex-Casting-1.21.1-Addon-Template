sealed interface {{ classname }}MessageCompanion<T> where T : {{ classname }}Message, T : Record {
    val type: Class<T>

    fun apply(msg: T, access: ServerAccess): Unit {
        {{ classname }}.LOGGER.debug("Server received packet from {}: {}", access.player().name.string, this)
        when (msg) {
            is {{ classname }}MessageC2S -> msg.applyOnServer(access)
            else -> {{ classname }}.LOGGER.warn("Message not handled on server: {}", msg::class)
        }
