package {{ kotlin_package }}

import {{ kotlin_package }}.client.NeoForge{{ classname }}Client
import {{ kotlin_package }}.datagen.NeoForge{{ classname }}Datagen
import net.neoforged.bus.api.IEventBus
import net.neoforged.fml.ModContainer
import net.neoforged.fml.ModList
import net.neoforged.fml.common.Mod

@Mod({{ classname }}.MODID)
class NeoForge{{ classname }}(modBus: IEventBus, container: ModContainer) {
    init {
        modBus.apply {
            addListener(NeoForge{{ classname }}Client::init)
            addListener(NeoForge{{ classname }}Datagen::init)
            addListener(NeoForge{{ classname }}Server::init)
        }
        {{ classname }}.init()
    }

    companion object {
        internal val container: ModContainer
            get() = ModList.get().getModContainerById({{ classname }}.MODID).get()
    }
}
